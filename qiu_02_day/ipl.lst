     1 00000000                                 ; hello-os
     2 00000000                                 ; TAB=4
     3 00000000                                 
     4                                          		ORG		0x7c00			; 指明程序装载地址
     5 00007C00                                 
     6 00007C00                                 ; 标准FAT12格式软盘专用的代码 Stand FAT12 format floppy code
     7 00007C00 EB 3C                           		JMP		entry
     8 00007C02 90                              		NOP					; 这两个字节是标准的跳转填充
     9 00007C03 48 45 4C 4C 4F 49 50 4C         		DB		"HELLOIPL"		; 启动扇区名称（8字节）(OEM Name, 8 bytes)
    10 00007C0B 0200                            		DW		512				; 每个扇区（sector）大小（必须512字节）(Bytes per Sector)
    11 00007C0D 01                              		DB		1				; 簇（cluster）大小（必须为1个扇区）(Sectors per Cluster)
    12 00007C0E 0001                            		DW		1				; FAT起始位置（一般为第一个扇区）(Reserved Sectors)
    13 00007C10 02                              		DB		2				; FAT个数（必须为2）(Number of FATS)
    14 00007C11 00E0                            		DW		224				; 根目录大小（一般为224项）(Root Entries)
    15 00007C13 0B40                            		DW		2880			; 该磁盘大小（必须为2880扇区1440*1024/512）(Total Sectors)
    16 00007C15 F0                              		DB		0xf0			; 磁盘类型（必须为0xf0）(Media Descriptor)
    17 00007C16 0009                            		DW		9				; FAT的长度（必须9扇区）(Sectors per FAT)
    18 00007C18 0012                            		DW		18				; 一个磁道（track）有几个扇区（必须为18）(Sectors per Track)
    19 00007C1A 0002                            		DW		2				; 磁头数（必须2）(Number of Heads)
    20 00007C1C 00000000                        		DD		0				; 不使用分区，必须是0(Hidden Sectors)
    21 00007C20 00000B40                        		DD		2880			; 重写一次磁盘大小(Large Sectors)
    22 00007C24                                 
    23 00007C24                                 		; 扩展BPB部分 (Extended BPB)
    24 00007C24 00                              		DB		0x00			; 驱动器号 (Drive Number)
    25 00007C25 00                              		DB		0x00			; 保留 (Reserved)
    26 00007C26 29                              		DB		0x29			; 扩展引导签名 (Extended Boot Signature)
    27 00007C27 12345678                        		DD		0x12345678		; 卷序列号 (Volume Serial Number)
    28 00007C2B 48 45 4C 4C 4F 2D 4F 53 20 20   		DB		"HELLO-OS   "	; 磁盘的名称（必须为11字节，不足填空格）(Volume Label, 11 bytes)
       00007C35 20 
    29 00007C36 46 41 54 31 32 20 20 20         		DB		"FAT12   "		; 磁盘格式名称（必须为8字节，不足填空格）(File System Type, 8 bytes)
    30 00007C3E                                 		; 注意：这里没有 RESB 18 了！
    31 00007C3E                                 
    32 00007C3E                                 ; 程序主体
    33 00007C3E                                 entry:
    34 00007C3E B8 0000                         		MOV		AX,0			; 初始化寄存器
    35 00007C41 8E D0                           		MOV		SS,AX
    36 00007C43 BC 7C00                         		MOV		SP,0x7c00
    37 00007C46 8E D8                           		MOV		DS,AX
    38 00007C48 8E C0                           		MOV		ES,AX
    39 00007C4A                                 
    40 00007C4A BE 7C62                         		MOV		SI,msg
    41 00007C4D                                 putloop:
    42 00007C4D 8A 04                           		MOV		AL,[SI]
    43 00007C4F 83 C6 01                        		ADD		SI,1			; 给SI加1
    44 00007C52 3C 00                           		CMP		AL,0
    45 00007C54 74 09                           		JE		fin
    46 00007C56 B4 0E                           		MOV		AH,0x0e			; 显示一个文字
    47 00007C58 BB 000F                         		MOV		BX,15			; 指定字符颜色
    48 00007C5B CD 10                           		INT		0x10			; 调用显卡BIOS
    49 00007C5D EB EE                           		JMP		putloop
    50 00007C5F                                 fin:
    51 00007C5F F4                              		HLT						; 让CPU停止，等待指令
    52 00007C60 EB FD                           		JMP		fin				; 无限循环
    53 00007C62                                 
    54 00007C62                                 msg:
    55 00007C62 0A 0A                           		DB		0x0a, 0x0a		; 换行两次
    56 00007C64 68 65 6C 6C 6F 2C 20 77 6F 72   		DB		"hello, world"
       00007C6E 6C 64 
    57 00007C70 0A                              		DB		0x0a			; 换行
    58 00007C71 00                              		DB		0
    59 00007C72                                 
    60 00007C72 00 00 00 00 00 00 00 00 00 00   		RESB	0x7dfe-$		; 填写0x00直到0x001fe
