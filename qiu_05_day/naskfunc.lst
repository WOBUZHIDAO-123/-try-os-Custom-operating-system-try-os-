     1 00000000                                 ; naskfunc
     2 00000000                                 ; TAB=4
     3 00000000                                 ;=====================================================================
     4 00000000                                 ; 本文件用于向 bootPack.c 提供底层硬件操作函数
     5 00000000                                 ; bootPack.c 中调用的 io_xxx 系列函数都在这里用汇编实现
     6 00000000                                 ; 因为 C 语言无法直接执行 IN/OUT/CLI/STI/HLT 等底层指令
     7 00000000                                 ;=====================================================================
     8 00000000                                 
     9 00000000                                 
    10 00000000                                 [FORMAT "WCOFF"]    ; 输出格式: Windows COFF 对象文件
    11 00000000                                                     ; bootPack.c 编译后的 .obj 文件会与此文件链接
    12 00000000                                 
    13 00000000                                 [BITS 32]           ; 生成 32 位保护模式代码
    14 00000000                                                     ; 我们的操作系统运行在 32 位保护模式下
    15 00000000                                 
    16 00000000                                 [INSTRSET "i486p"]  ; 允许使用 i486 及以上的指令集
    17 00000000                                 
    18 00000000                                 [FILE "naskfunc.nas"]
    19 00000000                                 
    20 00000000                                 ;--------------------------------------------------------------------------
    21 00000000                                 ; GLOBAL 声明 —— 将这些符号导出，供 C 语言链接使用
    22 00000000                                 ; C 语言调用时，会自动在函数名前加下划线，所以这里用 _io_hlt 等名称
    23 00000000                                 ;--------------------------------------------------------------------------
    24 00000000                                     GLOBAL _io_hlt              ; void io_hlt(void);
    25 00000000                                     GLOBAL _io_cli, _io_sti, _io_stihlt   ; 中断控制相关
    26 00000000                                     GLOBAL _io_in8, _io_in16, _io_in32    ; I/O 端口读取（8/16/32 位）
    27 00000000                                     GLOBAL _io_out8, _io_out16, _io_out32 ; I/O 端口写入（8/16/32 位）
    28 00000000                                     GLOBAL _io_load_eflags, _io_store_eflags  ; EFLAGS 寄存器操作
    29 00000000                                 
    30 00000000                                 
    31                                          [SECTION .text]
    32 00000000                                 
    33 00000000                                 ;==========================================================================
    34 00000000                                 ; 函数: io_hlt(void)
    35 00000000                                 ; 功能: 执行 HLT 指令，让 CPU 进入待机状态，直到下次中断发生才唤醒
    36 00000000                                 ; 参数: 无
    37 00000000                                 ; 返回: 无
    38 00000000                                 ; 寄存器: 不使用任何寄存器传递参数或返回值
    39 00000000                                 ;==========================================================================
    40 00000000                                 _io_hlt:
    41 00000000 F4                                  HLT                 ; Halt —— CPU 暂停执行，进入低功耗待机模式
    42 00000001                                                         ; 外部中断或异常到来时恢复执行下一条指令
    43 00000001 C3                                  RET                 ; 返回到 C 语言调用者
    44 00000002                                                         ; 返回值在栈上，由调用者清理
    45 00000002                                 
    46 00000002                                 
    47 00000002                                 ;==========================================================================
    48 00000002                                 ; 函数: io_cli(void)
    49 00000002                                 ; 功能: 执行 CLI (Clear Interrupt) 指令，关闭 CPU 的中断响应
    50 00000002                                 ;       此后 CPU 将忽略外部设备的中断请求，直到执行 STI 重新开启
    51 00000002                                 ; 参数: 无
    52 00000002                                 ; 返回: 无
    53 00000002                                 ; 寄存器: 不使用
    54 00000002                                 ;==========================================================================
    55 00000002                                 _io_cli:
    56 00000002 FA                                  CLI                 ; Clear Interrupt —— 清除 IF 标志位（EFLAGS 第 9 位）
    57 00000003                                                         ; IF=0 时，CPU 不再响应可屏蔽中断（INTR 引脚来的中断）
    58 00000003 C3                                  RET
    59 00000004                                 
    60 00000004                                 
    61 00000004                                 ;==========================================================================
    62 00000004                                 ; 函数: io_sti(void)
    63 00000004                                 ; 功能: 执行 STI (Set Interrupt) 指令，开启 CPU 的中断响应
    64 00000004                                 ;       重新允许 CPU 接收外部设备的中断请求
    65 00000004                                 ; 参数: 无
    66 00000004                                 ; 返回: 无
    67 00000004                                 ; 寄存器: 不使用
    68 00000004                                 ;==========================================================================
    69 00000004                                 _io_sti:
    70 00000004 FB                                  STI                 ; Set Interrupt —— 设置 IF 标志位（EFLAGS 第 9 位）
    71 00000005                                                         ; IF=1 时，CPU 恢复响应可屏蔽中断
    72 00000005 C3                                  RET
    73 00000006                                 
    74 00000006                                 
    75 00000006                                 ;==========================================================================
    76 00000006                                 ; 函数: io_stihlt(void)
    77 00000006                                 ; 功能: 先开中断，再立即执行 HLT 待机
    78 00000006                                 ;       典型用途：操作系统空闲时调用，既能响应中断，又能省电
    79 00000006                                 ; 参数: 无
    80 00000006                                 ; 返回: 无
    81 00000006                                 ; 寄存器: 不使用
    82 00000006                                 ;==========================================================================
    83 00000006                                 _io_stihlt:
    84 00000006 FB                                  STI                 ; 先开中断 —— 确保 HLT 后中断能唤醒 CPU
    85 00000007 F4                                  HLT                 ; 再待机 —— 等待下一次中断到来
    86 00000008 C3                                  RET
    87 00000009                                 
    88 00000009                                 
    89 00000009                                 ;==========================================================================
    90 00000009                                 ; 函数: io_in8(int port) port就是设备端口号
    91 00000009                                 ; 功能: 从指定的 I/O 端口读取 8 位（1 字节）数据
    92 00000009                                 ; 参数: port —— I/O 端口地址（0x0000~0xFFFF），通过栈传递
    93 00000009                                 ; 返回: 读取到的 8 位数据，零扩展到 32 位后返回
    94 00000009                                 ; 寄存器:
    95 00000009                                 ;   EDX ← port（I/O 指令 IN 要求端口号必须放在 DX 寄存器中）
    96 00000009                                 ;   EAX ← 返回值（函数的返回值固定放在 EAX 中）
    97 00000009                                 ;   AL  ← IN 指令从端口读到的 8 位数据
    98 00000009                                 ; 栈布局:
    99 00000009                                 ;   [ESP+0] = 返回地址（CALL 指令压入）
   100 00000009                                 ;   [ESP+4] = 第 1 个参数 port
   101 00000009                                 ;==========================================================================
   102 00000009                                 _io_in8:
   103 00000009 8B 54 24 04                         MOV     EDX,[ESP+4]     ; EDX = port（第 1 个参数，在返回地址上方 4 字节）
   104 0000000D                                                             ; I/O 指令 IN/OUT 必须用 DX 或 EDX 指定端口号
   105 0000000D B8 00000000                         MOV     EAX,0           ; EAX 高位置 0，保证返回值干净（高 24 位 = 0）
   106 00000012 EC                                  IN      AL,DX           ; AL = 从端口 DX 读入的 8 位数据
   107 00000013                                                             ; IN AL,DX 从 8 位端口读 8 位 → AL
   108 00000013 C3                                  RET                     ; 返回 EAX（低 8 位 AL 是有效数据）
   109 00000014                                 
   110 00000014                                 
   111 00000014                                 ;==========================================================================
   112 00000014                                 ; 函数: io_in16(int port)
   113 00000014                                 ; 功能: 从指定的 I/O 端口读取 16 位（2 字节）数据
   114 00000014                                 ; 参数: port —— I/O 端口地址
   115 00000014                                 ; 返回: 读取到的 16 位数据，零扩展到 32 位后返回
   116 00000014                                 ; 寄存器:
   117 00000014                                 ;   EDX ← port
   118 00000014                                 ;   EAX ← 返回值
   119 00000014                                 ;   AX  ← IN 指令从端口读到的 16 位数据
   120 00000014                                 ;==========================================================================
   121 00000014                                 _io_in16:
   122 00000014 8B 54 24 04                         MOV     EDX,[ESP+4]     ; EDX = port
   123 00000018 B8 00000000                         MOV     EAX,0           ; EAX 高 16 位置 0
   124 0000001D 66 ED                               IN      AX,DX           ; AX = 从端口 DX 读入的 16 位数据
   125 0000001F                                                             ; IN AX,DX 从 16 位端口读 16 位 → AX
   126 0000001F C3                                  RET
   127 00000020                                 
   128 00000020                                 
   129 00000020                                 ;==========================================================================
   130 00000020                                 ; 函数: io_in32(int port)
   131 00000020                                 ; 功能: 从指定的 I/O 端口读取 32 位（4 字节）数据
   132 00000020                                 ; 参数: port —— I/O 端口地址
   133 00000020                                 ; 返回: 读取到的 32 位数据
   134 00000020                                 ; 寄存器:
   135 00000020                                 ;   EDX ← port
   136 00000020                                 ;   EAX ← IN 指令读到的 32 位数据（同时也是返回值）
   137 00000020                                 ;==========================================================================
   138 00000020                                 _io_in32:
   139 00000020 8B 54 24 04                         MOV     EDX,[ESP+4]     ; EDX = port
   140 00000024 ED                                  IN      EAX,DX          ; EAX = 从端口 DX 读入的 32 位数据
   141 00000025                                                             ; IN EAX,DX 从 32 位端口读 32 位 → EAX
   142 00000025 C3                                  RET                     ; EAX 直接作为返回值返回，无需额外处理
   143 00000026                                 
   144 00000026                                 
   145 00000026                                 ;==========================================================================
   146 00000026                                 ; 函数: io_out8(int port, int data)
   147 00000026                                 ; 功能: 向指定的 I/O 端口写入 8 位（1 字节）数据
   148 00000026                                 ; 参数: port —— I/O 端口地址（第 1 个参数）
   149 00000026                                 ;       data —— 要写入的 8 位数据（第 2 个参数）
   150 00000026                                 ; 返回: 无
   151 00000026                                 ; 寄存器:
   152 00000026                                 ;   EDX ← port
   153 00000026                                 ;   AL  ← data（OUT 指令将 AL 的内容写到 DX 指定的端口）
   154 00000026                                 ; 栈布局:
   155 00000026                                 ;   [ESP+0] = 返回地址
   156 00000026                                 ;   [ESP+4] = 第 1 个参数 port
   157 00000026                                 ;   [ESP+8] = 第 2 个参数 data
   158 00000026                                 ;==========================================================================
   159 00000026                                 _io_out8:
   160 00000026 8B 54 24 04                         MOV     EDX,[ESP+4]     ; EDX = port
   161 0000002A 8A 44 24 08                         MOV     AL,[ESP+8]      ; AL  = data（只取低 8 位，高 24 位忽略）
   162 0000002E EE                                  OUT     DX,AL           ; 将 AL 的 8 位数据写入端口 DX
   163 0000002F                                                             ; OUT DX,AL 是标准的 8 位 I/O 写入指令
   164 0000002F C3                                  RET
   165 00000030                                 
   166 00000030                                 
   167 00000030                                 ;==========================================================================
   168 00000030                                 ; 函数: io_out16(int port, int data)
   169 00000030                                 ; 功能: 向指定的 I/O 端口写入 16 位（2 字节）数据
   170 00000030                                 ; 参数: port —— I/O 端口地址
   171 00000030                                 ;       data —— 要写入的 16 位数据
   172 00000030                                 ; 返回: 无
   173 00000030                                 ; 寄存器:
   174 00000030                                 ;   EDX ← port
   175 00000030                                 ;   EAX ← data（仅低 16 位 AX 有效）
   176 00000030                                 ;==========================================================================
   177 00000030                                 _io_out16:
   178 00000030 8B 54 24 04                         MOV     EDX,[ESP+4]     ; EDX = port
   179 00000034 8B 44 24 08                         MOV     EAX,[ESP+8]     ; EAX = data（OUT 指令只使用 AX 部分）
   180 00000038 66 EF                               OUT     DX,AX           ; 将 AX 的 16 位数据写入端口 DX
   181 0000003A C3                                  RET
   182 0000003B                                 
   183 0000003B                                 
   184 0000003B                                 ;==========================================================================
   185 0000003B                                 ; 函数: io_out32(int port, int data)
   186 0000003B                                 ; 功能: 向指定的 I/O 端口写入 32 位（4 字节）数据
   187 0000003B                                 ; 参数: port —— I/O 端口地址
   188 0000003B                                 ;       data —— 要写入的 32 位数据
   189 0000003B                                 ; 返回: 无
   190 0000003B                                 ; 寄存器:
   191 0000003B                                 ;   EDX ← port
   192 0000003B                                 ;   EAX ← data（完整的 32 位数据）
   193 0000003B                                 ;==========================================================================
   194 0000003B                                 _io_out32:
   195 0000003B 8B 54 24 04                         MOV     EDX,[ESP+4]     ; EDX = port
   196 0000003F 8B 44 24 08                         MOV     EAX,[ESP+8]     ; EAX = data
   197 00000043 EF                                  OUT     DX,EAX          ; 将 EAX 的 32 位数据写入端口 DX
   198 00000044 C3                                  RET
   199 00000045                                 
   200 00000045                                 
   201 00000045                                 ;==========================================================================
   202 00000045                                 ; 函数: io_load_eflags(void)
   203 00000045                                 ; 功能: 读取当前 CPU 的 EFLAGS 寄存器并返回
   204 00000045                                 ;       常用于在修改关键标志前保存当前状态
   205 00000045                                 ; 参数: 无
   206 00000045                                 ; 返回: EFLAGS 寄存器的 32 位值
   207 00000045                                 ; 寄存器:
   208 00000045                                 ;   EAX ← EFLAGS（通过栈间接传递：PUSHFD → POP EAX）
   209 00000045                                 ; 注意:
   210 00000045                                 ;   EFLAGS 中每位代表一个标志，例如：
   211 00000045                                 ;     Bit 0  (CF)  = 进位标志
   212 00000045                                 ;     Bit 6  (ZF)  = 零标志
   213 00000045                                 ;     Bit 9  (IF)  = 中断许可标志（我们最常用的）
   214 00000045                                 ;     Bit 7  (SF)  = 符号标志
   215 00000045                                 ;==========================================================================
   216 00000045                                 _io_load_eflags:
   217 00000045 9C                                  PUSHFD              ; 将 EFLAGS 寄存器的值压入栈
   218 00000046                                                         ; PUSHFD = Push EFLAGS Double-word (32位)
   219 00000046 58                                  POP     EAX         ; 弹出到 EAX，作为函数返回值
   220 00000047                                                         ; 相当于 EFLAGS → 栈 → EAX
   221 00000047 C3                                  RET
   222 00000048                                 
   223 00000048                                 
   224 00000048                                 ;==========================================================================
   225 00000048                                 ; 函数: io_store_eflags(int eflags)
   226 00000048                                 ; 功能: 将指定的值写入 EFLAGS 寄存器，恢复之前保存的 CPU 状态
   227 00000048                                 ;       一般与 io_load_eflags 配对使用
   228 00000048                                 ; 参数: eflags —— 要写入 EFLAGS 寄存器的 32 位值
   229 00000048                                 ; 返回: 无
   230 00000048                                 ; 寄存器:
   231 00000048                                 ;   EAX ← eflags（准备压栈）
   232 00000048                                 ;   栈 → EFLAGS（通过 POPFD 实现）
   233 00000048                                 ; 流程:
   234 00000048                                 ;   参数 eflags → EAX → 压栈 PUSH → 弹入 EFLAGS (POPFD)
   235 00000048                                 ;==========================================================================
   236 00000048                                 _io_store_eflags:
   237 00000048 8B 44 24 04                         MOV     EAX,[ESP+4]     ; EAX = eflags（第 1 个参数）
   238 0000004C 50                                  PUSH    EAX             ; 将 eflags 压入栈
   239 0000004D 9D                                  POPFD                   ; 从栈弹出到 EFLAGS 寄存器
   240 0000004E                                                             ; POPFD = Pop stack to EFLAGS Double-word
   241 0000004E                                                             ; 完成 EFLAGS 的恢复
   242 0000004E C3                                  RET                     ; 在执行RET时，EAX的值就是返回值