; first-os
; TAB=4

; ============================================================
; BOOT_INFO 相关定义（由引导扇区 IPL 写入）
; 这些地址位于内存低端，内核启动后从这里读取系统信息
; ============================================================
CYLS   EQU  0x0ff0   ; 引导扇区探测到的柱面数（Cylinders）
LEDS   EQU  0x0ff1   ; 键盘 LED 状态（Num Lock / Caps Lock / Scroll Lock 等）
VMODE  EQU  0x0ff2   ; 显示模式信息（多少位色彩等）
SCRNX  EQU  0x0ff4   ; 屏幕分辨率 X（水平像素数）
SCRNY  EQU  0x0ff6   ; 屏幕分辨率 Y（垂直像素数）
VRAM   EQU  0x0ff8   ; 显存（VRAM）的起始地址

; -----------------------------------------------------------
; 内核代码入口
; IPL 从磁盘加载本程序后，会跳转到 0xc200 处执行
; -----------------------------------------------------------
        ORG   0xc200   ; 指定本程序的加载地址为 0xc200

; -----------------------------------------------------------
; 初始化显示模式：设置 VGA 图形模式 320x200x8bit 彩色
; -----------------------------------------------------------
        MOV   AL, 0x13   ; VGA 模式 0x13：320×200×8 位彩色（256 色）
        MOV   AH, 0x00   ; 功能号 0x00：设置显示模式
        INT   0x10       ; 调用 BIOS 视频中断
        ; 将当前显示模式信息保存到 BOOT_INFO 区域，供后续使用
        MOV   BYTE [VMODE], 8      ; 保存色彩位数（8 位，即 256 色）
        MOV   WORD [SCRNX], 320    ; 保存水平分辨率 320
        MOV   WORD [SCRNY], 200    ; 保存垂直分辨率 200
        MOV   DWORD [VRAM], 0x000a0000   ; 保存显存起始地址 0xA0000

; -----------------------------------------------------------
; 获取键盘 LED 状态（从 BIOS 读取）
; -----------------------------------------------------------
        MOV   AH, 0x02   ; 功能号 0x02：获取键盘标志字节
        INT   0x16       ; 调用键盘 BIOS 中断
        MOV   [LEDS], AL ; 将 LED 状态字节保存到 BOOT_INFO 区域

; -----------------------------------------------------------
; 内核主循环（当前为占位，仅做暂停）
; -----------------------------------------------------------
fin:
        HLT              ; 暂停 CPU，等待下一次中断
        JMP   fin        ; 无限循环（真正的内核会在此处实现消息循环或任务调度）